#!/usr/bin/env bash
set -euo pipefail
# Resolve the real path of this script, following symlinks (works on macOS + Linux).
SOURCE="$0"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  # Resolve relative symlink
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
KBUTILLIB_ROOT="$(cd "$(dirname "$SOURCE")/.." && pwd)"
PYTHON="${KBU_PYTHON:-python3}"
exec env PYTHONPATH="$KBUTILLIB_ROOT/src${PYTHONPATH:+:$PYTHONPATH}" "$PYTHON" -m kbutillib "$@"
